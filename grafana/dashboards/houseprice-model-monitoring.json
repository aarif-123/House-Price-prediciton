  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Predictions per second (all endpoints).",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "sum(rate(model_predictions_total[1m]))",
          "legendFormat": "predictions/s",
          "refId": "A"
        }
      ],
      "title": "Prediction Throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "p95 inference latency from custom histogram.",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(model_prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "title": "Inference Latency p95 (s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Mean absolute error computed from histogram sum/count.",
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "sum(rate(model_prediction_abs_error_usd_sum[15m])) / sum(rate(model_prediction_abs_error_usd_count[15m]))",
          "legendFormat": "MAE (15m)",
          "refId": "A"
        }
      ],
      "title": "Online MAE (USD)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "RMSE computed as sqrt(mean squared error).",
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "sqrt(sum(rate(model_prediction_sq_error_usd2_sum[15m])) / sum(rate(model_prediction_sq_error_usd2_count[15m])))",
          "legendFormat": "RMSE (15m)",
          "refId": "A"
        }
      ],
      "title": "Online RMSE (USD)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Pending predictions awaiting ground truth (in-memory TTL store).",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "sum(model_predictions_pending_feedback)",
          "legendFormat": "pending",
          "refId": "A"
        }
      ],
      "title": "Pending Feedback",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Feedback volume and status.",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "sum by (status) (rate(model_feedback_total[5m]))",
          "legendFormat": "{{status}}/s",
          "refId": "A"
        }
      ],
      "title": "Feedback Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
